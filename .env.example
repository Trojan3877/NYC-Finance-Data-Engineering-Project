# .env.example – Copy to .env and fill in real values before running docker-compose.
# NEVER commit the actual .env file to source control.

POSTGRES_USER=finance_user
POSTGRES_PASSWORD=change_me_before_use
POSTGRES_DB=nyc_finance

# Replace <POSTGRES_USER>, <POSTGRES_PASSWORD> and <POSTGRES_DB> with the values above.
DATABASE_URL=postgresql://finance_user:change_me_before_use@postgres:5432/nyc_finance

RAW_DATA_DIR=/app/data/raw
PROCESSED_DATA_DIR=/app/data/processed

# Path to the trained ML model (relative to the container's /app working dir)
MODEL_PATH=models/model.pkl

# Drift detection sensitivity (fraction; default 0.10 = 10 %)
DRIFT_THRESHOLD=0.10
